# chief-of-staff-communication-agent — required environment variables
# Copy to .env and fill in. Committed config never holds values (see CLAUDE.md: Do NOT regress).

# Azure OpenAI — chat (recommendations, drafting, style-matching)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI — embeddings (RAG index; separate resource: cheleq-alpha-3)
AZURE_OPENAI_EMBED_API_KEY=
AZURE_OPENAI_EMBED_ENDPOINT=
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

# Supabase — dedicated project "chief-of-staff-comms" (ref frhromdjjmczranjcnfz).
# NEVER point these at another project's ref.
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Netlify (dashboard UI deploys)
NETLIFY_AUTH_TOKEN=

# Twilio (SMS + WhatsApp sandbox) — pending Arthur's approval to reuse cheleq's
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_NUMBER=

# Asana (task linking) — pending demo workspace decision
# ASANA_ACCESS_TOKEN=
# ASANA_WORKSPACE_GID=
