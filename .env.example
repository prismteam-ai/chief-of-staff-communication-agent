# Copy to .env. MODE=mock uses local mock servers with dummy creds.
# MODE=real points the same connectors at the real APIs (needs real creds).
MODE=mock

# Mock server host/ports (one FastAPI app, one port by default)
MOCK_HOST=127.0.0.1
MOCK_PORT=8900

# Host roots. Each real SDK appends its own native path.
# In real mode set: GMAIL=https://gmail.googleapis.com, X=https://api.twitter.com,
# WHATSAPP=https://graph.facebook.com, ASANA=https://app.asana.com/api/1.0
GMAIL_BASE_URL=http://127.0.0.1:8900
X_BASE_URL=http://127.0.0.1:8900
WHATSAPP_BASE_URL=http://127.0.0.1:8900
ASANA_BASE_URL=http://127.0.0.1:8900/api/1.0

# Credentials (dummy in mock mode)
GMAIL_USER_ID=me
X_BEARER_TOKEN=mock-x-bearer
X_USER_ID=1000000000000000001
WHATSAPP_API_VERSION=v19.0
WHATSAPP_PHONE_ID=100000000000001
WHATSAPP_TOKEN=mock-whatsapp-token
ASANA_TOKEN=mock-asana-token
ASANA_WORKSPACE_GID=1200000000000001

# --- Real-mode credentials (leave blank for MODE=mock) ----------------------
# Gmail: create an OAuth "Desktop app" client in Google Cloud, run the one-time
# consent to mint a refresh token (see RUNNING.md), then paste it here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# GOOGLE_TOKEN_URI and GOOGLE_SCOPES have working defaults; override only if needed.

# X: OAuth1 user context (needed for DMs + posting). Bearer token above covers reads.
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# WhatsApp: the verify token you register with Meta + the app secret used to
# validate the X-Hub-Signature-256 on inbound webhooks.
WHATSAPP_VERIFY_TOKEN=mock-verify-token
WHATSAPP_APP_SECRET=

# The executive whose inbox this is (used for direction + style later)
OWNER_NAME=Dmitrii Konyrev
OWNER_EMAIL=konyrevdmitriy@gmail.com
OWNER_X_HANDLE=dmitrii_cos
OWNER_WHATSAPP=+15550000001
