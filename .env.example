# Value-free configuration contract.
# Copy only the minimum variables required for an approved local operation.
# Never place a credential value in this file.

# Application and AWS runtime identity
APP_ENV=
APP_BASE_URL=
AWS_ACCOUNT_ID=
AWS_REGION=
AWS_PROFILE=
BEDROCK_EMBEDDING_PROFILE_ID=
BEDROCK_GENERATION_PROFILE_ID=

# Product authentication
COGNITO_USER_POOL_ID=
COGNITO_USER_POOL_CLIENT_ID=
COGNITO_DOMAIN=

# Gmail OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Microsoft Graph OAuth candidate
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=
MICROSOFT_REDIRECT_URI=

# Generic second-mailbox candidate
IMAP_HOST=
IMAP_PORT=
IMAP_USERNAME=
IMAP_PASSWORD=
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=

# Twilio SMS and WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

# X OAuth
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=

# LinkedIn OAuth, only if an approved API capability exists
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# Asana OAuth
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=
ASANA_REDIRECT_URI=

# Conditional observability integration
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
