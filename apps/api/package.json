{
  "name": "@chief/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/router.ts",
      "default": "./dist/router.js"
    },
    "./handler": {
      "types": "./src/handler.ts",
      "default": "./dist/handler.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src"
  },
  "dependencies": {
    "@chief/agent": "workspace:*",
    "@chief/approval-outbox": "workspace:*",
    "@chief/connector-core": "workspace:*",
    "@chief/connector-gmail": "workspace:*",
    "@chief/connector-imap-smtp": "workspace:*",
    "@chief/connector-linkedin": "workspace:*",
    "@chief/connector-microsoft-graph": "workspace:*",
    "@chief/connector-twilio": "workspace:*",
    "@chief/connector-x": "workspace:*",
    "@chief/contracts": "workspace:*",
    "@chief/demo-fixtures": "workspace:*",
    "@chief/domain": "workspace:*",
    "@chief/model-gateway": "workspace:*",
    "@chief/observability": "workspace:*",
    "@chief/persistence-dynamodb": "workspace:*",
    "@chief/rag": "workspace:*",
    "@chief/work-management-asana": "workspace:*",
    "@trpc/server": "11.18.0",
    "aws-jwt-verify": "5.2.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@chief/tsconfig": "workspace:*",
    "@types/aws-lambda": "8.10.162",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
