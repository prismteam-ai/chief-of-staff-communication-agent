{
  "name": "@chief/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/router.ts",
      "default": "./dist/router.js"
    },
    "./handler": {
      "types": "./src/handler.ts",
      "default": "./dist/handler.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src"
  },
  "dependencies": {
    "@chief/contracts": "workspace:*",
    "@chief/observability": "workspace:*",
    "@trpc/server": "11.18.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@chief/tsconfig": "workspace:*",
    "@types/aws-lambda": "8.10.162",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
