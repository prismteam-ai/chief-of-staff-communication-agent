{
  "name": "@chief/demo-fixtures",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src"
  },
  "dependencies": {
    "@chief/contracts": "workspace:*",
    "@chief/domain": "workspace:*",
    "@faker-js/faker": "10.5.0"
  },
  "devDependencies": {
    "@chief/tsconfig": "workspace:*",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
