{
  "name": "@chief/work-management-asana",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./acceptance": {
      "types": "./src/acceptance.ts",
      "default": "./dist/acceptance.js"
    },
    "./acceptance-cli": {
      "types": "./src/acceptance-cli.ts",
      "default": "./dist/acceptance-cli.js"
    }
  },
  "scripts": {
    "accept": "node dist/acceptance-cli.js",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src"
  },
  "dependencies": {
    "@chief/connector-core": "workspace:*",
    "@chief/connector-testkit": "workspace:*",
    "@chief/contracts": "workspace:*",
    "@chief/domain": "workspace:*"
  },
  "devDependencies": {
    "@chief/tsconfig": "workspace:*",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
