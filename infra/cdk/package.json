{
  "name": "@chief/infra-cdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "chief-cdk": "dist/bin/app.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint bin lib test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run test",
    "synth": "cdk synth --app \"node --enable-source-maps dist/bin/app.js\" --no-lookups --context account=417242953053 --context region=us-east-2"
  },
  "dependencies": {
    "aws-cdk-lib": "2.261.0",
    "constructs": "10.7.0"
  },
  "devDependencies": {
    "@chief/api": "workspace:*",
    "@chief/execution-worker": "workspace:*",
    "@chief/ingestion-worker": "workspace:*",
    "@chief/mcp": "workspace:*",
    "@chief/tsconfig": "workspace:*",
    "@chief/web": "workspace:*",
    "@types/node": "22.19.17",
    "aws-cdk": "2.1131.0",
    "esbuild": "0.28.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
