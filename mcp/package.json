{
  "name": "@chief-of-staff/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pidgeot MCP server (stdio) for the Chief of Staff Communication Agent — Task 11, design.md §8. npx-runnable standalone (see the 'why standalone' note below).",
  "bin": {
