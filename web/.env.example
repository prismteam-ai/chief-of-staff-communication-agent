# Copy to .env.local (dev) / set in the deploy env.

# Postgres (Neon / Vercel Postgres / local). Prisma reads this.
DATABASE_URL="postgresql://cos:cos@localhost:5432/cos?schema=public"

# Shared HS256 secret — MUST match the Python API's AUTH_JWT_SECRET so the session
# token minted here verifies there. Use a long random value in production.
AUTH_JWT_SECRET="dev-insecure-change-me-in-production-0123456789"

# Base URL of the Python FastAPI app API.
COS_API_URL="http://localhost:8000"
